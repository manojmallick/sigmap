{
  "ContextForge: Start session": {
    "prefix": "cf-start",
    "body": [
      "I'm starting a new coding session on **${1:feature/bug/task}**.",
      "",
      "Please use the `read_context` MCP tool to load the full project signature map before we begin. Once loaded, summarise:",
      "1. Which modules are most relevant to ${1}",
      "2. Any types / interfaces I should be aware of",
      "3. Suggested files to open first",
      "",
      "${0}"
    ],
    "description": "Session start: load full context and get orientation"
  },

  "ContextForge: Checkpoint": {
    "prefix": "cf-checkpoint",
    "body": [
      "Create a session checkpoint using the `create_checkpoint` MCP tool with note: \"${1:brief description of current state}\".",
      "",
      "After the checkpoint, summarise:",
      "- What we have accomplished so far",
      "- What is still outstanding",
      "- Any blockers or decisions pending",
      "${0}"
    ],
    "description": "Create a mid-session checkpoint with state summary"
  },

  "ContextForge: Read full context": {
    "prefix": "cf-context",
    "body": [
      "Use the `read_context` MCP tool (no arguments) to load all code signatures for this project.",
      "Once loaded, confirm the total token count and number of modules indexed.",
      "${0}"
    ],
    "description": "Load the complete project signature context"
  },

  "ContextForge: Read specific module": {
    "prefix": "cf-module",
    "body": [
      "Use the `read_context` MCP tool with `{ \"module\": \"${1:src/path/to/module}\" }` to load signatures for that module only.",
      "${0}"
    ],
    "description": "Load context for a specific module or subdirectory"
  },

  "ContextForge: Search signatures": {
    "prefix": "cf-search",
    "body": [
      "Use the `search_signatures` MCP tool with `{ \"query\": \"${1:function or class name}\" }` to find all matching signatures across the codebase.",
      "${0}"
    ],
    "description": "Search for a function, class, or method by keyword"
  },

  "ContextForge: Get import graph": {
    "prefix": "cf-map-imports",
    "body": [
      "Use the `get_map` MCP tool with `{ \"type\": \"imports\" }` to display the project dependency graph.",
      "Identify any circular dependencies or unusually high fan-in modules.",
      "${0}"
    ],
    "description": "Show the import/dependency graph from PROJECT_MAP.md"
  },

  "ContextForge: Get class hierarchy": {
    "prefix": "cf-map-classes",
    "body": [
      "Use the `get_map` MCP tool with `{ \"type\": \"classes\" }` to display the class inheritance and implementation hierarchy.",
      "${0}"
    ],
    "description": "Show class hierarchy (extends / implements) from PROJECT_MAP.md"
  },

  "ContextForge: Get route table": {
    "prefix": "cf-map-routes",
    "body": [
      "Use the `get_map` MCP tool with `{ \"type\": \"routes\" }` to display all HTTP routes defined in this project.",
      "${0}"
    ],
    "description": "Show HTTP route table from PROJECT_MAP.md"
  },

  "ContextForge: Debug session": {
    "prefix": "cf-debug",
    "body": [
      "I'm debugging an issue in **${1:module/file}**.",
      "",
      "1. Load context with `read_context { \"module\": \"${1}\" }`",
      "2. The symptom is: ${2:describe the bug}",
      "3. It occurs when: ${3:describe the trigger / reproduction steps}",
      "",
      "Based on the signatures, identify likely suspects and suggest a debugging strategy.",
      "${0}"
    ],
    "description": "Structured debug session with context loading"
  },

  "ContextForge: Write PR description": {
    "prefix": "cf-pr",
    "body": [
      "Generate a pull request description for the changes I've made to **${1:list of files/modules}**.",
      "",
      "Use `read_context { \"module\": \"${1}\" }` to understand the existing code, then write:",
      "- **What:** One-paragraph summary of the change",
      "- **Why:** Motivation and context",
      "- **How:** Technical approach",
      "- **Testing:** How to verify correctness",
      "${0}"
    ],
    "description": "Generate a PR description informed by context"
  },

  "ContextForge: Write tests": {
    "prefix": "cf-test",
    "body": [
      "Write unit tests for **${1:function or class name}** in `${2:file path}`.",
      "",
      "First load context with `search_signatures { \"query\": \"${1}\" }` to see the current signature.",
      "Then write tests that cover:",
      "- Happy path",
      "- Edge cases (null, empty, boundary values)",
      "- Error / exception paths",
      "${0}"
    ],
    "description": "Write tests for a function or class with context"
  },

  "ContextForge: Refactor": {
    "prefix": "cf-refactor",
    "body": [
      "I want to refactor **${1:function/class/module}** to improve ${2:readability/performance/testability}.",
      "",
      "Load context for the relevant area, then:",
      "1. Identify what the current code does",
      "2. Point out the main issues",
      "3. Propose a refactored version without changing external behaviour",
      "${0}"
    ],
    "description": "Context-aware refactoring session"
  },

  "ContextForge: Code review": {
    "prefix": "cf-review",
    "body": [
      "Review the code I'm about to paste (or in `${1:file path}`) for:",
      "- Correctness and logic errors",
      "- Security issues (OWASP Top 10)",
      "- Performance concerns",
      "- Adherence to existing patterns (use `read_context` to check)",
      "",
      "Provide actionable, specific feedback with line references where possible.",
      "${0}"
    ],
    "description": "Structured code review with OWASP and pattern checks"
  },

  "ContextForge: New feature": {
    "prefix": "cf-feature",
    "body": [
      "I need to implement **${1:feature name}**.",
      "",
      "1. Load full context with `read_context`",
      "2. Identify which existing modules this feature touches",
      "3. Propose an implementation plan with:",
      "   - Files to create / modify",
      "   - New types / interfaces needed",
      "   - Integration points",
      "4. Then implement step by step",
      "${0}"
    ],
    "description": "Structured new feature implementation with context"
  },

  "ContextForge: Performance audit": {
    "prefix": "cf-perf",
    "body": [
      "Audit `${1:module or function}` for performance issues.",
      "",
      "Load its signatures with `search_signatures { \"query\": \"${1}\" }`, then analyse for:",
      "- Unnecessary re-computation or repeated work",
      "- N+1 query patterns",
      "- Large allocations or memory pressure",
      "- Missing memoisation or caching opportunities",
      "${0}"
    ],
    "description": "Performance audit with context-informed analysis"
  },

  "ContextForge: Security scan": {
    "prefix": "cf-security",
    "body": [
      "Perform a security review of `${1:file or module}` focused on OWASP Top 10:",
