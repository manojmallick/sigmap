{
  "name": "sigmap",
  "displayName": "SigMap",
  "description": "Zero-dependency AI context engine — keeps copilot-instructions.md fresh automatically.",
  "version": "1.5.0",
  "publisher": "manojmallick",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "AI", "Machine Learning"],
  "keywords": ["copilot", "ai-context", "token-reduction", "code-signatures", "claude", "cursor", "sigmap", "context", "llm", "zero-dependency", "mcp"],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "qna": "https://github.com/manojmallick/sigmap/issues",
  "activationEvents": ["onStartupFinished"],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sigmap.regenerate",
        "title": "SigMap: Regenerate Context"
      },
      {
        "command": "sigmap.openContext",
        "title": "SigMap: Open Context File"
      }
    ],
    "configuration": {
      "title": "SigMap",
      "properties": {
        "sigmap.scriptPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to gen-context.js. Leave empty to auto-detect from workspace root."
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/manojmallick/sigmap.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/manojmallick/sigmap/issues"
  },
  "homepage": "https://manojmallick.github.io/sigmap/"
}
